# Copy this file to src/environments/.env and replace placeholders with real values.
# Keep exactly one active DATABASE_URL and one active DIRECT_URL.
# Never commit real passwords, Supabase connection strings, or AI provider API keys.

# Local PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vensight_db?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/vensight_db?schema=public"

# Supabase examples
# Runtime Prisma Client: use the transaction pooler for serverless/auto-scaling hosts.
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Prisma CLI migrations/introspection: use the direct database URL or session pooler.
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"

SESSION_SECRET="replace-with-a-long-random-secret"
SEEDED_ADMIN_EMAIL="imarkovychi@gmail.com"
SEEDED_ADMIN_PASSWORD="replace-with-a-strong-local-or-production-admin-password"
ALLOWED_ORIGINS="http://localhost:4200,http://localhost:4300,http://localhost:4000"
API_ONLY="false"
PUBLIC_SITE_URL="https://vensight.com"
TRUST_PROXY="false"
API_REQUEST_LOGS="false"

AI_PROVIDER="mock"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b"

# Backend-only AI provider secrets. Never expose these through Angular/browser config.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="qwen/qwen-2.5-7b-instruct:free"

GOOGLE_AI_API_KEY=""
GOOGLE_MODEL="gemini-2.5-flash"

# Backend-only search discovery providers. SearchApi is primary; Tavily is optional fallback.
SEARCH_PROVIDER="disabled"
SEARCH_API_KEY=""
SEARCH_API_ENGINE="google"
SEARCH_FALLBACK_PROVIDER="tavily"
TAVILY_API_KEY=""
