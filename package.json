{
  "name": "vensight",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "npm run prisma:generate && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "npm run prisma:generate && npm run test:api && npm run test:web",
    "test:api": "vitest run src/api src/server.spec.ts",
    "test:web": "ng test",
    "typecheck": "npm run prisma:generate && tsc --build --pretty false",
    "serve:ssr:vensight": "node dist/vensight/server/server.mjs",
    "env:check": "tsx scripts/check-env.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "supabase:version": "supabase --version",
    "supabase:help": "supabase --help",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link",
    "supabase:projects": "supabase projects list",
    "supabase:migrations": "supabase migration list",
    "supabase:apply-initial-migration": "tsx scripts/apply-initial-migration.ts",
    "supabase:rls:enable": "tsx scripts/enable-supabase-rls.ts",
    "supabase:rls:check": "tsx scripts/check-supabase-rls.ts",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "overrides": {
    "@hono/node-server": "^1.19.14"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/forms": "^21.2.14",
    "@angular/platform-browser": "^21.2.14",
    "@angular/platform-server": "^21.2.14",
    "@angular/router": "^21.2.14",
    "@angular/ssr": "^21.2.8",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "pg": "^8.20.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.14",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^20.17.19",
    "@types/pg": "^8.20.0",
    "jasmine-core": "^6.2.0",
    "jsdom": "^28.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "prisma": "^7.8.0",
    "supabase": "^2.101.0",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
